{
    "functions": {
        "api/admin/*.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/admin/config.php",
            "status": 404
        },
        {
            "src": "/admin/(.*)",
            "dest": "/api/admin/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}
